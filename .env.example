# Backend Server URL (must include /api/auth path for Better Auth)
# After Render deployment, replace with your actual Render URL
NEXT_PUBLIC_SERVER_URL=https://your-app.onrender.com/api/auth

# Backend API URL (without /api/auth path for REST API calls)
# After Render deployment, replace with your actual Render URL
NEXT_PUBLIC_API_URL=https://your-app.onrender.com
